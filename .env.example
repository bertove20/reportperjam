# ============================================
# Tim Hourly Report Bot — Environment Config
# ============================================

# Telegram Bot
TG_BOT_TOKEN=123456:ABC-your-bot-token-here
TG_REPORT_GROUP=-1001234567890

# Timezone (sesuaikan dengan lokasi operasi)
TZ=Asia/Phnom_Penh

# ============================================
# ENGINE TYPE A — Cookie-based (Asia77 style)
# Untuk panel yang pakai Cloudflare + session cookie
# ============================================

BRAND_A_KEY=BRAND_A
BRAND_A_NAME=Brand A
BRAND_A_DOMAIN=panel-a.example.com
BRAND_A_ENGINE=asia77
# Cookie auth: dikelola via cookies.json (lihat panduan)

BRAND_B_KEY=BRAND_B
BRAND_B_NAME=Brand B
BRAND_B_DOMAIN=panel-b.example.com
BRAND_B_ENGINE=asia77

BRAND_C_KEY=BRAND_C
BRAND_C_NAME=Brand C
BRAND_C_DOMAIN=panel-c.example.com
BRAND_C_ENGINE=asia77

BRAND_E_KEY=BRAND_E
BRAND_E_NAME=panen77
BRAND_E_DOMAIN=panel-e.example.com
BRAND_E_ENGINE=asia77
BRAND_E_IDUS=0

# ============================================
# ENGINE TYPE B — JWT-based (Syntech/WIS style)
# Untuk panel yang pakai JWT token authentication
# ============================================

BRAND_D_KEY=BRAND_D
BRAND_D_NAME=Brand D
BRAND_D_DOMAIN=panel-d.example.com
BRAND_D_ENGINE=syntech
BRAND_D_USER=username_here
BRAND_D_PASS=password_here
BRAND_D_PIN=123456
