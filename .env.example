# ============================================
# Tim Hourly Report Bot — Environment Config
# ============================================

# Telegram Bot
TG_BOT_TOKEN=123456:ABC-your-bot-token-here
TG_REPORT_GROUP=-1001234567890

# Timezone
TZ=Asia/Phnom_Penh

# Server
PORT=3000
ENCRYPTION_KEY=your-random-32-hex-string
JWT_SECRET=your-random-32-hex-string

# ============================================
# PostgreSQL Database
# ============================================
# Option 1: Connection URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/reportbot

# Option 2: Individual params (jika DATABASE_URL tidak diset)
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASS=password
# PG_DB=reportbot

# ============================================
# Multi-Tenant SaaS
# ============================================
BASE_DOMAIN=report.grup138.com

# ============================================
# Puppeteer (opsional, untuk VPS)
# ============================================
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
